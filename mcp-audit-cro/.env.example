# Required: base URL of your Railway deployment (no trailing slash)
RAILWAY_APP_URL=https://your-app.up.railway.app

# Required: shared secret for Audit CRO write operations.
# Must match AUDIT_CRO_INTERNAL_SECRET set in Railway Variables.
# The MCP server sends this as: X-AUDIT-CRO-SECRET: <value>
# The Railway endpoints reject requests with a missing or wrong header (401).
AUDIT_CRO_INTERNAL_SECRET=change-this-secret

# Optional: set to 1 for verbose stderr logging
MCP_DEBUG=
